---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getWebPageStructuredData } from "../../lib/structuredData";

const title = "Security Disclosure Policy | Sayyidi Shaarani";
const description =
  "Plain-language security disclosure policy and engagement boundaries.";

const structuredData = getWebPageStructuredData({
  path: "/disclosure/",
  title,
  description,
});
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/disclosure/"
  structuredData={structuredData}
>
  <section class="hero" aria-labelledby="disclosure-title">
    <h1 id="disclosure-title">Security Disclosure Policy</h1>
    <div class="summaryBox" aria-label="Plain-language summary">
      <h2>Plain-Language Summary</h2>
      <ul>
        <li>I only test systems with written permission from the owner.</li>
        <li>I do not test or scan random third-party systems.</li>
        <li>If you find an issue in a system, contact that system owner directly.</li>
      </ul>
    </div>

    <p>
      This policy explains how inspections are handled safely, legally, and
      within agreed boundaries.
    </p>
    <p>
      No active testing, automated scanning, exploitation, or validation is
      performed without explicit permission from the system owner.
    </p>

    <h2>Scope &amp; Boundaries</h2>
    <p>This policy applies only to work performed under formal engagement.</p>
    <p>
      This practice does not authorize or request unsolicited testing, scanning, or probing of any third-party systems.
    </p>
    <p>
      If you believe a vulnerability exists in an organization’s system, you should contact the system owner directly or follow their published disclosure process.
    </p>

    <h2>Professional Conduct</h2>
    <p>
      All security engagements are governed by written scope, authorization, and mutually agreed boundaries.
    </p>
    <p>This reflects a commitment to lawful, ethical, and structured security practice.</p>

    <h2>No Bug Bounty Program</h2>
    <p>
      This practice does not operate a public bug bounty program and does not provide monetary rewards for unsolicited vulnerability reports.
    </p>

    <h2>Reporting a Security Concern</h2>
    <p>
      If you wish to report a security concern related to work performed under this inspection practice, please contact:
    </p>
    <p><a href="mailto:salam@sayyidishaarani.com">salam@sayyidishaarani.com</a></p>
    <p>
      Please include sufficient technical detail to allow independent reproduction and validation of the issue. Reports should describe:
    </p>
    <ul>
      <li>The affected asset or endpoint</li>
      <li>The observed behavior</li>
      <li>Steps to reproduce (if known)</li>
      <li>Relevant timestamps or context</li>
    </ul>
    <p>Incomplete or speculative reports may not be actionable.</p>
  </section>
</BaseLayout>

<style>
  section {
    max-width: 66ch;
  }

  .hero h2 {
    margin-top: var(--space-3);
  }

  .hero ul {
    margin-bottom: var(--space-3);
  }

  .summaryBox {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-soft);
    padding: var(--space-2);
    margin: var(--space-2) 0 var(--space-3);
  }

  .summaryBox h2 {
    margin-top: 0;
  }

</style>
